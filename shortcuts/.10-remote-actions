#!/bin/sh

. ~/.profile

[ -z "$REMOTE_HOST" ] && REMOTE_HOST=shadow

action="${1:-"$(termux-dialog sheet -t pcact -v \
	"Start Local Server,Stop Local Server,System Actions,
		MPV Remote Server,Kill MPV Remote Server" | \
	sed -n 's|^\s*"index": \([0-9]*\)\s*$|\1|p')"}"

addhost() { [ -x "$(command -v sshadd)" ] && sshadd "$1"; }

case "$action" in

	0)
		termux-wake-lock &
		dg pull &
		git -C ~/.termux pull
		for prog in sshd syncthing; do
			pidof -q "$prog" || "$prog" &
		done >/dev/null 2>&1
		# su -c setprop service.adb.tcp.port 43896
		# su -c start adbd
		;;

	1)
		pkill syncthing
		pkill sshd
		su -c stop adbd
		termux-wake-unlock
		;;

	2)
		addhost "$REMOTE_HOST"
		SYSACT_REMOTE_PC="$REMOTE_HOST" ~/.local/bin/sysact "$@"
		;;

	3)
		addhost "$REMOTE_HOST"
		ssh "$REMOTE_HOST" "sh -c 'nohup mpv --idle >/dev/null 2>&1 &'"
		am start com.husudosu.mpvremote/com.husudosu.mpvremote.MainActivity
		;;

	4)
		addhost "$REMOTE_HOST"
		ssh "$REMOTE_HOST" pkill mpv
		;;

esac
